MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/career-copilot?retryWrites=true&w=majority
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000
# Lock CORS to your frontend URL in production (e.g. https://your-app.vercel.app)
# Leave unset or use * for local development
ALLOWED_ORIGIN=http://localhost:3000,http://localhost:5173
# JWT signing secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_random_hex_string_here
# Google OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
